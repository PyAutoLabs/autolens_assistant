# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.venv/
venv/
env/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# HPC sync config — machine-specific, contains personal paths
hpc/sync.conf
hpc/sync_jump.conf

# PyAutoFit output — generated, typically too large to commit
output/
failed/

# Agent working directory — Python scripts and Markdown notes get committed;
# plot outputs and data dumps do not. Convention: skill-generated plots land
# in `work/plots/<context>/`; FITS / numpy / pickle dumps in `work/output/`.
work/plots/
work/output/
work/audit/
work/*.png
work/*.pdf
work/*.jpg
work/*.jpeg
work/*.fits
work/*.npy
work/*.pkl
work/*.hdf5
work/*.h5

# Sandbox caches
.numba_cache/
.matplotlib/

# Cloned source repos (when set up via al_setup_environment in dev mode).
# Users may keep these elsewhere; if cloned as siblings, they live outside
# this repo. If cloned inside, ignore them.
/sources/

# Literature wiki PDFs — keep locally, never commit. `papers/` is the in-repo
# convention used by `al_ingest_paper`, but PDFs can live anywhere.
papers/

# Maintainer-mode sentinel — when present at the repo root, the agent treats
# the session as template maintenance work (no profile capture, no auto-commit,
# no newcomer-mode defaults). See CLAUDE.md Part 1 "Maintainer mode".
.maintainer

# Claude Code agent worktrees — ephemeral, machine-local.
.claude/worktrees/

# Per-clone science journal (wiki/project/). This is each user's own running
# record — created on demand from the templates, never shipped with the
# template repo. The templates and README themselves are tracked; the live
# profile and dated entries are not. See CLAUDE.md Part 1 "First-interaction
# protocol" and wiki/project/README.md.
wiki/project/profile.md
wiki/project/[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]-*.md

# Per-clone modeling pipelines (scripts/). The template ships only
# scripts/template.py; the typed pipelines (imaging.py, interferometer.py) and
# their SLaM context file are generated per clone by the init-slam skill from
# autolens_workspace, so they are never committed to the template repo. See
# CLAUDE.md Part 2 "Modeling Scripts" and scripts/CLAUDE.md.
scripts/imaging.py
scripts/interferometer.py
scripts/slam_claude.md
