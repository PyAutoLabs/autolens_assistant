#!/bin/bash -l

#SBATCH -J base_imaging
#SBATCH --partition=gpu
#SBATCH --gres=gpu:1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=1
#SBATCH --mem=32gb
#SBATCH --time=08:00:00
#SBATCH --array=0-0
#SBATCH -o output/output.%A_%a.out
#SBATCH -e error/error.%A_%a.err
#SBATCH --mail-type=END,FAIL
#SBATCH --mail-user=james.w.nightingale@durham.ac.uk

# -------------------------------
# Environment
#
# Set PROJECT_PATH before submitting:
#   export PROJECT_PATH=/path/to/your/project
# -------------------------------
source $PROJECT_PATH/activate.sh

# -------------------------------
# Dataset list
#
# Each entry is the name of a subdirectory inside dataset/.
# Omit --dataset entirely if the project has a single dataset.
# Update --array above to match the number of datasets (0 to N-1).
# -------------------------------
datasets=(
simple
)

# -------------------------------
# Select dataset for this array task
# -------------------------------
INDEX=$SLURM_ARRAY_TASK_ID
dataset="${datasets[$INDEX]}"

echo "=========================================="
echo "Array job index: $INDEX"
echo "Dataset: $dataset"
date
nvidia-smi

# -------------------------------
# Run the analysis script.
#
# All path management is handled inside scripts/base.py via Path(__file__).
# pixel_scale and n_batch are read from dataset/$dataset/info.json automatically.
# -------------------------------
python3 $PROJECT_PATH/scripts/base.py --dataset=$dataset

echo "Finished dataset: $dataset"
date
